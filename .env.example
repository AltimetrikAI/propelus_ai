# Propelus AI Taxonomy Framework - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/propelus_taxonomy
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=propelus_taxonomy
DATABASE_USER=propelus_admin
DATABASE_PASSWORD=your_secure_password

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password

# Redis connection settings
REDIS_POOL_SIZE=10
REDIS_TIMEOUT=5
REDIS_RETRY_ATTEMPTS=3

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3 Buckets
S3_BRONZE_BUCKET=propelus-taxonomy-bronze-dev
S3_SILVER_BUCKET=propelus-taxonomy-silver-dev
S3_GOLD_BUCKET=propelus-taxonomy-gold-dev
S3_REGION=us-east-1

# SQS Queues
SILVER_PROCESSING_QUEUE=propelus-taxonomy-silver-processing-dev
MAPPING_RULES_QUEUE=propelus-taxonomy-mapping-rules-dev
DLQ_URL=propelus-taxonomy-dlq-dev

# Lambda Functions
BRONZE_INGESTION_LAMBDA=propelus-taxonomy-bronze-ingestion-dev
SILVER_PROCESSING_LAMBDA=propelus-taxonomy-silver-processing-dev
MAPPING_RULES_LAMBDA=propelus-taxonomy-mapping-rules-dev
TRANSLATION_LAMBDA=propelus-taxonomy-translation-dev

# =============================================================================
# AWS Bedrock Configuration
# =============================================================================
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.1

# Alternative models (uncomment to use)
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# BEDROCK_MODEL_ID=amazon.titan-text-express-v1

# =============================================================================
# Application Configuration
# =============================================================================
ENVIRONMENT=development
PROJECT_NAME=propelus-taxonomy
VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DEBUG_LOGGING=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=300
API_RATE_LIMIT=1000
API_BURST_LIMIT=2000

# CORS settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Admin UI Configuration
# =============================================================================
ADMIN_UI_HOST=0.0.0.0
ADMIN_UI_PORT=8501
API_BASE_URL=http://localhost:8000/api/v1
TRANSLATION_API_URL=http://localhost:8000/api/v1

# Authentication (placeholder - implement actual auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_change_me
JWT_SECRET_KEY=your_jwt_secret_key_change_me

# =============================================================================
# Processing Configuration
# =============================================================================

# Confidence thresholds
AUTO_APPROVAL_THRESHOLD=90.0
HUMAN_REVIEW_THRESHOLD=70.0
REJECTION_THRESHOLD=60.0

# Processing limits
MAX_BATCH_SIZE=1000
MAX_PROCESSING_TIME_MINUTES=30
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=60

# Translation service
ENABLE_TRANSLATION_CACHING=true
TRANSLATION_CACHE_TTL_SECONDS=3600
MAX_TRANSLATION_ALTERNATIVES=5

# AI/ML settings
ENABLE_AI_MAPPING=true
AI_CONFIDENCE_BOOST=5.0
SEMANTIC_SIMILARITY_THRESHOLD=0.8

# =============================================================================
# Monitoring & Observability
# =============================================================================

# CloudWatch
CLOUDWATCH_LOG_GROUP=/aws/lambda/propelus-taxonomy
CLOUDWATCH_LOG_RETENTION_DAYS=30
ENABLE_CLOUDWATCH_INSIGHTS=true

# Metrics
ENABLE_CUSTOM_METRICS=true
METRICS_NAMESPACE=PropellusTaxonomy
PUSH_METRICS_INTERVAL_SECONDS=60

# Alerts
ALERTS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:propelus-alerts
ALERT_EMAIL=alerts@propelus.ai

# Health checks
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10

# =============================================================================
# Security Configuration
# =============================================================================

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key
ENABLE_FIELD_ENCRYPTION=true
ENCRYPTION_ALGORITHM=AES-256-GCM

# SSL/TLS
SSL_CERT_PATH=/path/to/ssl/cert.pem
SSL_KEY_PATH=/path/to/ssl/key.pem
FORCE_HTTPS=false

# API Security
API_KEY_REQUIRED=false
API_KEY_HEADER=X-API-Key
RATE_LIMITING_ENABLED=true

# HIPAA Compliance
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
ENABLE_DATA_MASKING=true

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_DATA_LINEAGE=true
ENABLE_MASTER_TAXONOMY_VERSIONING=true
ENABLE_BULK_OPERATIONS=true
ENABLE_ASYNC_PROCESSING=true
ENABLE_CONTEXT_RULES=true
ENABLE_ISSUING_AUTHORITY_OVERRIDES=true

# Experimental features
ENABLE_ML_CONFIDENCE_ADJUSTMENT=false
ENABLE_AUTOMATED_RULE_GENERATION=false
ENABLE_REAL_TIME_ANALYTICS=false

# =============================================================================
# Development Settings
# =============================================================================

# Only set these in development environment
DEV_CREATE_TEST_DATA=false
DEV_ENABLE_DEBUG_ENDPOINTS=false
DEV_BYPASS_AUTHENTICATION=false
DEV_LOG_ALL_REQUESTS=false
DEV_MOCK_EXTERNAL_SERVICES=false

# Test database (for running tests)
TEST_DATABASE_URL=postgresql://test:test@localhost:5433/propelus_taxonomy_test

# =============================================================================
# Data Retention & Lifecycle
# =============================================================================

# S3 Lifecycle policies (days)
BRONZE_DATA_RETENTION_DAYS=90
SILVER_DATA_RETENTION_DAYS=365
GOLD_DATA_RETENTION_DAYS=2555  # 7 years

# Database cleanup
AUDIT_LOG_RETENTION_DAYS=2555
PROCESSING_LOG_RETENTION_DAYS=90
TRANSLATION_PATTERN_RETENTION_DAYS=365

# =============================================================================
# Performance Tuning
# =============================================================================

# Lambda configuration
LAMBDA_MEMORY_SIZE=1024
LAMBDA_TIMEOUT_SECONDS=900
LAMBDA_RESERVED_CONCURRENCY=100

# Database performance
DATABASE_STATEMENT_TIMEOUT_SECONDS=30
DATABASE_IDLE_CONNECTION_TIMEOUT_SECONDS=300
ENABLE_CONNECTION_POOLING=true

# Redis performance
REDIS_CONNECTION_POOL_SIZE=10
REDIS_COMMAND_TIMEOUT_SECONDS=5
ENABLE_REDIS_CLUSTER=false

# =============================================================================
# Business Rules Configuration
# =============================================================================

# Context rules
ENABLE_ACLS_AHA_MAPPING=true
ENABLE_ARRT_NATIONAL_MAPPING=true
ENABLE_STATE_OVERRIDE_LOGIC=true

# Mapping preferences
PREFER_EXACT_MATCHES=true
ENABLE_FUZZY_MATCHING=true
FUZZY_MATCH_THRESHOLD=80

# Human review workflow
REQUIRE_DUAL_APPROVAL=false
REVIEWER_TIMEOUT_HOURS=24
AUTO_ESCALATE_AFTER_HOURS=72

# =============================================================================
# Integration Settings
# =============================================================================

# External APIs
EVERCHECK_API_URL=https://api.evercheck.com/v1
EVERCHECK_API_KEY=your_evercheck_api_key
EVERCHECK_TIMEOUT_SECONDS=30

# Webhook endpoints
MAPPING_COMPLETION_WEBHOOK_URL=https://your-domain.com/webhooks/mapping-complete
REVIEW_REQUIRED_WEBHOOK_URL=https://your-domain.com/webhooks/review-required

# SFTP/FTP settings (if needed)
# SFTP_HOST=sftp.client.com
# SFTP_USERNAME=propelus
# SFTP_PRIVATE_KEY_PATH=/path/to/private/key

# =============================================================================
# Backup & Recovery
# =============================================================================
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_SCHEDULE_CRON=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
ENABLE_POINT_IN_TIME_RECOVERY=true

# Cross-region backup
BACKUP_REGION=us-west-2
ENABLE_CROSS_REGION_BACKUP=false